# Copy to ~/.config/kmsrdp/kmsrdp.env (mode 600 - it holds a password) and
# edit, then: systemctl --user enable --now kmsrdp.service
#
# If left unset, kmsrdp-server generates a random one-shot password and
# prints it to the journal (journalctl --user -u kmsrdp) on each start.

KMSRDP_USER=kmsrdp
KMSRDP_PASSWORD=change-me

# Optional: listen address and port (defaults 0.0.0.0 and 3389).
# KMSRDP_BIND=127.0.0.1
# KMSRDP_PORT=3389

# Optional: capture one specific active DRM connector. Use CARD:CONNECTOR
# (for example card1:DP-1) if the connector name is ambiguous across cards.
# KMSRDP_DISPLAY=DP-1

# Optional: TLS identity. By default a self-signed cert/key is created once
# under $XDG_STATE_HOME/kmsrdp (systemd StateDirectory) and reused.
# KMSRDP_TLS_HOSTS=myhost,192.168.1.10
# KMSRDP_TLS_DIR=/path/to/dir
# KMSRDP_TLS_CERT=/path/to/tls.crt
# KMSRDP_TLS_KEY=/path/to/tls.key
# KMSRDP_TLS_EPHEMERAL=1

# Optional: structured logging (stderr). Same filter syntax as RUST_LOG.
# KMSRDP_LOG=info
# KMSRDP_LOG=kmsrdp=debug,rdpcore_server=info
# KMSRDP_LOG_FORMAT=json
