# Copy to ~/.config/kmsrdp/kmsrdp.env (mode 600 - it holds a password) and
# edit, then: systemctl --user enable --now kmsrdp.service
#
# If left unset, kmsrdp-server generates a random one-shot password and
# prints it to the journal (journalctl --user -u kmsrdp) on each start.

KMSRDP_USER=kmsrdp
KMSRDP_PASSWORD=change-me

# Optional: capture one specific active DRM connector. Use CARD:CONNECTOR
# (for example card1:DP-1) if the connector name is ambiguous across cards.
# KMSRDP_DISPLAY=DP-1
