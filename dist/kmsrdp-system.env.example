# Copy to /etc/kmsrdp/kmsrdp.env (mode 600 - it holds a password) and edit,
# then: systemctl enable --now kmsrdp.service
#
# This is the RDP login (client-facing) credential, not a Linux account -
# the server runs as root and follows whichever Linux user currently has
# the active graphical session (auto-detected via logind).
#
# If left unset, kmsrdp-server generates a random one-shot password and
# prints it to the journal (journalctl -u kmsrdp) on each start.

KMSRDP_USER=kmsrdp
KMSRDP_PASSWORD=change-me

# Optional: listen address and port (defaults 0.0.0.0 and 3389).
# KMSRDP_BIND=127.0.0.1
# KMSRDP_PORT=3389

# Optional: capture one specific active DRM connector. Use CARD:CONNECTOR
# (for example card1:DP-1) if the connector name is ambiguous across cards.
# KMSRDP_DISPLAY=DP-1

# Optional: TLS identity. By default a self-signed cert/key is created once
# under /var/lib/kmsrdp (systemd StateDirectory) and reused across restarts.
# KMSRDP_TLS_HOSTS=myhost,192.168.1.10
# KMSRDP_TLS_DIR=/path/to/dir
# KMSRDP_TLS_CERT=/path/to/tls.crt
# KMSRDP_TLS_KEY=/path/to/tls.key
# KMSRDP_TLS_EPHEMERAL=1

# Optional: structured logging (stderr). Same filter syntax as RUST_LOG.
# KMSRDP_LOG=info
# KMSRDP_LOG=kmsrdp=debug,rdpcore_server=info
# KMSRDP_LOG_FORMAT=json

# Startup checks refuse privileged ports (<1024) without CAP_NET_BIND_SERVICE,
# empty KMSRDP_PASSWORD when set, and invalid KMSRDP_DISPLAY / TLS path pairs.
# Missing parec/paplay/pactl or fusermount3 are warnings only.
