# Copy to /etc/kmsrdp/kmsrdp.env (mode 600 - it holds a password) and edit,
# then: systemctl enable --now kmsrdp.service
#
# This is the RDP login (client-facing) credential, not a Linux account -
# the server runs as root and follows whichever Linux user currently has
# the active graphical session (auto-detected via logind).
#
# If left unset, kmsrdp-server generates a random one-shot password and
# prints it to the journal (journalctl -u kmsrdp) on each start.

KMSRDP_USER=kmsrdp
KMSRDP_PASSWORD=change-me

# Optional: capture one specific active DRM connector. Use CARD:CONNECTOR
# (for example card1:DP-1) if the connector name is ambiguous across cards.
# KMSRDP_DISPLAY=DP-1
